{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2023"],
    "types": ["node"],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      // Extensions import the bare "@earendil-works/pi-ai" specifier, but pi's
      // extension loader aliases it to the /compat entrypoint at runtime. Point
      // tsc at the same compat surface so types match what actually executes.
      "@earendil-works/pi-ai": [
        "node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-ai/dist/compat.d.ts"
      ],
      "@earendil-works/pi-tui": [
        "node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-tui/dist/index.d.ts"
      ]
    }
  },
  "include": ["index.ts", "index.test.ts"]
}
